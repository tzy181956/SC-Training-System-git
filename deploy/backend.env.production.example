# Copy this file to /opt/sc-training-system/backend/.env on the server
# and replace the placeholder values before starting the backend.
# Never commit a real production secret.

APP_ENV=production
SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=sqlite:////opt/sc-training-system-data/training.db
CORS_ORIGINS=["https://your-domain.example"]
CORS_ORIGIN_REGEX=
