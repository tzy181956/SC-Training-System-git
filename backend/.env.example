# Example backend environment configuration
# Local development can run without backend/.env.
# For production, copy this file to backend/.env and fill in the required values manually.

APP_ENV=development
APP_NAME=Training Management Platform
API_PREFIX=/api
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Development defaults when backend/.env is absent:
# - SECRET_KEY falls back to a local dev-only value.
# - DATABASE_URL falls back to backend/training.db.
# - CORS_ORIGINS falls back to http://localhost:5173 and http://127.0.0.1:5173.

# Production notes:
# 1. Set APP_ENV=production.
# 2. SECRET_KEY must be a long random string and cannot stay at dev-secret-key-change-me.
# 3. DATABASE_URL must be explicitly configured.
# 4. CORS_ORIGINS must be explicitly configured as a JSON array.
# 5. If the production values above are missing, backend startup will fail immediately.

# Production example values (replace before use):
# SECRET_KEY=replace-with-a-long-random-secret
# DATABASE_URL=sqlite:////opt/sc-training-system-data/training.db
# CORS_ORIGINS=["https://your-domain.example"]

# Keep this empty in production unless you clearly understand the risk.
# Broad patterns such as https?://.* are not recommended for production.
CORS_ORIGIN_REGEX=
