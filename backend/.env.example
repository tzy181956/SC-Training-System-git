# Example backend environment configuration
# Copy this file to backend/.env and fill in the production values manually.

APP_NAME=Training Management Platform
API_PREFIX=/api
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite example inside the code directory (not recommended for production):
# DATABASE_URL=sqlite:////path/to/your/repo/backend/training.db

# Recommended SQLite example for a dedicated server data directory:
DATABASE_URL=sqlite:////opt/sc-training-system-data/training.db

# Use an explicit JSON array of allowed origins in production.
CORS_ORIGINS=["https://your-domain.example"]

# Use a specific regex only if you really need one.
# Keep this disabled when CORS_ORIGINS is already explicit.
CORS_ORIGIN_REGEX=^$
